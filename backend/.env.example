NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
BASE_URL=http://localhost:3001

# PostgreSQL (from docker-compose)
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/travelmemory

# JWT
JWT_SECRET=change-this-secret-in-production-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin (used by seed script)
ADMIN_EMAIL=admin@travelmemory.local
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Owner

# Storage
STORAGE_TYPE=local
UPLOADS_DIR=./uploads

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# pgAdmin (docker-compose)
POSTGRES_PASSWORD=postgres123
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin123
